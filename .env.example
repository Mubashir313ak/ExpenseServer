# MongoDB connection string (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/expense_tracker?retryWrites=true&w=majority

# Secret used to sign JWTs. Use a long, random value in production.
JWT_SECRET=change-me-to-a-long-random-string

# Optional: token lifetime (defaults to 7d)
JWT_EXPIRES_IN=7d

# Optional: local dev port (defaults to 3000)
PORT=3000

# Optional: environment (development | production)
NODE_ENV=development
